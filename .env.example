# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
UNIPILE_DSN=https://api8.unipile.com:13859
UNIPILE_API_KEY=your-unipile-api-key

# ── Optional: AI features ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Webhook verification ───────────────────────────────────────────
WEBHOOK_SECRET=any-random-string

# ── Optional: Email reports ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-app-password
REPORT_FROM=noreply@yourdomain.com
REPORT_EMAIL=you@yourdomain.com

# ── Optional: Health alerts ───────────────────────────────────────────────────
HEALTH_ALERT_WEBHOOK=https://hooks.slack.com/services/...
HEALTH_ALERT_EMAIL=admin@yourdomain.com

# ── Auto-set by setup wizard ──────────────────────────────────────────────────
# SETUP_COMPLETE=true
